From 098e5d16e7a537e90db7a84c7cb9f97495340162 Mon Sep 17 00:00:00 2001
From: Akash Yadav <akashyadav@appdevforall.org>
Date: Thu, 26 Mar 2026 14:17:23 +0530
Subject: [PATCH 2/9] fix: replace usage of JavaVersion.current() with
 androidJavaVersion()

JavaVersion.current() tries to use system properties like 'java.version' and 'java.runtime.version'
which are either unavailable on Android, or are set to 0. This makes JavaVersion.current() fail when
it is queried.

We resolve this by replacing usage of JavaVersion.current() with the newly-introduced
androidJavaVersion() function, which checks for Android version and returns JavaVersion instance
based on Java features available in that version of Android. If the runtime is non-ART, it falls
back to the usual JavaVersion.current() path to ensure compatibility with existing code.

Signed-off-by: Akash Yadav <akashyadav@appdevforall.org>
---
 .../cli/jvm/modules/javaVersionUtils.kt       |  3 ++-
 .../JvmEnvironmentConfigurator.kt             |  3 ++-
 .../kotlin/test/KotlinTestUtils.java          |  3 ++-
 .../jetbrains/kotlin/utils/JavaVersionUtil.kt | 26 +++++++++++++++++++
 .../org/jetbrains/kotlin/utils/KotlinPaths.kt |  4 +--
 5 files changed, 34 insertions(+), 5 deletions(-)
 create mode 100644 compiler/util/src/org/jetbrains/kotlin/utils/JavaVersionUtil.kt

diff --git a/compiler/cli/cli-base/src/org/jetbrains/kotlin/cli/jvm/modules/javaVersionUtils.kt b/compiler/cli/cli-base/src/org/jetbrains/kotlin/cli/jvm/modules/javaVersionUtils.kt
index 00f375e5a091..bd21c23de942 100644
--- a/compiler/cli/cli-base/src/org/jetbrains/kotlin/cli/jvm/modules/javaVersionUtils.kt
+++ b/compiler/cli/cli-base/src/org/jetbrains/kotlin/cli/jvm/modules/javaVersionUtils.kt
@@ -6,7 +6,8 @@
 package org.jetbrains.kotlin.cli.jvm.modules
 
 import com.intellij.util.lang.JavaVersion
+import org.jetbrains.kotlin.utils.currentJavaVersion
 
 fun isAtLeastJava9(): Boolean {
-    return JavaVersion.current() >= JavaVersion.compose(9)
+    return currentJavaVersion() >= JavaVersion.compose(9)
 }
diff --git a/compiler/tests-common-new/testFixtures/org/jetbrains/kotlin/test/services/configuration/JvmEnvironmentConfigurator.kt b/compiler/tests-common-new/testFixtures/org/jetbrains/kotlin/test/services/configuration/JvmEnvironmentConfigurator.kt
index 99ae3e637228..a1e9037b29fc 100644
