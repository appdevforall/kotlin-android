diff --git a/compiler/util/src/org/jetbrains/kotlin/utils/JavaVersionUtil.kt b/compiler/util/src/org/jetbrains/kotlin/utils/JavaVersionUtil.kt
new file mode 100644
index 000000000000..7fa8aa09ad5b
--- /dev/null
+++ b/compiler/util/src/org/jetbrains/kotlin/utils/JavaVersionUtil.kt
@@ -0,0 +1,26 @@
+/*
+ * Copyright 2010-2026 JetBrains s.r.o. and Kotlin Programming Language contributors.
+ * Use of this source code is governed by the Apache 2.0 license that can be found in the license/LICENSE.txt file.
+ */
+
+package org.jetbrains.kotlin.utils
+
+import com.intellij.util.lang.JavaVersion
+
+private val androidJavaVersion by lazy { androidJavaVersion() }
+
+fun currentJavaVersion(): JavaVersion =
+    androidJavaVersion ?: JavaVersion.current()
+
+fun androidJavaVersion(): JavaVersion? =
+    runCatching {
+        val buildClass = Class.forName($$"android.os.Build$VERSION")
+        val sdkInt = buildClass.getField("SDK_INT").getInt(null)
+        val featureVersion = when {
+            sdkInt >= 34 -> 17
+            sdkInt >= 31 -> 11
+            else -> 8
+        }
+
+        JavaVersion.compose(featureVersion)
+    }.getOrNull()
diff --git a/compiler/util/src/org/jetbrains/kotlin/utils/KotlinPaths.kt b/compiler/util/src/org/jetbrains/kotlin/utils/KotlinPaths.kt
index 8e0934daba6d..04bd822d4a8d 100644
--- a/compiler/util/src/org/jetbrains/kotlin/utils/KotlinPaths.kt
+++ b/compiler/util/src/org/jetbrains/kotlin/utils/KotlinPaths.kt
@@ -114,8 +114,8 @@ interface KotlinPaths {
         Empty(),
         StdLib(Jar.StdLib, gen = {
             when {
-                JavaVersion.current() >= JavaVersion.compose(8) -> listOf(Jar.StdLibJdk7, Jar.StdLibJdk8)
-                JavaVersion.current() >= JavaVersion.compose(7) -> listOf(Jar.StdLibJdk7)
+                currentJavaVersion() >= JavaVersion.compose(8) -> listOf(Jar.StdLibJdk7, Jar.StdLibJdk8)
+                currentJavaVersion() >= JavaVersion.compose(7) -> listOf(Jar.StdLibJdk7)
                 else -> emptyList()
             }
         }),
