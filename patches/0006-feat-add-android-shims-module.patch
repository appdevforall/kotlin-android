diff --git a/prepare/ide-plugin-dependencies/android-shims/build.gradle.kts b/prepare/ide-plugin-dependencies/android-shims/build.gradle.kts
new file mode 100644
index 000000000000..8dbcf1627d3f
--- /dev/null
+++ b/prepare/ide-plugin-dependencies/android-shims/build.gradle.kts
@@ -0,0 +1,80 @@
+import java.util.zip.ZipFile
+
+plugins {
+    kotlin("jvm")
+}
+
+configureJvmToolchain(JdkMajorVersion.JDK_11_0)
+
+val hiddenApiBypassVersion = "6.1"
+
+val hiddenapibypassAar by configurations.creating {
+    isCanBeConsumed = false
+    isCanBeResolved = true
+    isTransitive = false
+    attributes {
+        attribute(Usage.USAGE_ATTRIBUTE, objects.named(Usage.JAVA_RUNTIME))
+        attribute(Category.CATEGORY_ATTRIBUTE, objects.named(Category.LIBRARY))
+    }
+}
+
+val hiddenapibypassClassesJar = layout.buildDirectory.file("hiddenapibypass/classes.jar")
+
+abstract class ExtractAarClassesJar : DefaultTask() {
+    @get:InputFiles
+    @get:PathSensitive(PathSensitivity.RELATIVE)
+    abstract val aarFiles: ConfigurableFileCollection
+
+    @get:OutputFile
+    abstract val outputJar: RegularFileProperty
+
+    @TaskAction
+    fun extract() {
+        val aarFile = aarFiles.singleFile
+        val outFile = outputJar.get().asFile
+        outFile.parentFile.mkdirs()
+        ZipFile(aarFile).use { zip ->
+            val entry = zip.getEntry("classes.jar")
+                ?: throw GradleException("No classes.jar found in $aarFile")
+            zip.getInputStream(entry).use { input ->
+                outFile.outputStream().use { output -> input.copyTo(output) }
+            }
+        }
+    }
+}
+
+val extractHiddenapibypass by tasks.registering(ExtractAarClassesJar::class) {
+    aarFiles.from(hiddenapibypassAar)
+    outputJar.set(hiddenapibypassClassesJar)
+}
+
+dependencies {
+    hiddenapibypassAar("org.lsposed.hiddenapibypass:hiddenapibypass:$hiddenApiBypassVersion")
+
+    compileOnly(commonDependency("com.google.android", "android"))
+    compileOnly(intellijCore())
+    compileOnly(files(hiddenapibypassClassesJar).builtBy(extractHiddenapibypass))
+    compileOnly(libs.kotlinx.coroutines.core)
+
+    val httpClientVersion = libs.versions.http.client.get()
+    val jsonVersion = libs.versions.json.get()
+    configurations.all {
+        resolutionStrategy.eachDependency {
+            if (requested.group == "org.apache.httpcomponents" && requested.name == "httpclient") {
+                useVersion(httpClientVersion)
+            }
+            if (requested.group == "org.json" && requested.name == "json") {
+                useVersion(jsonVersion)
+            }
+        }
+    }
+}
+
+tasks.withType<JavaCompile>().configureEach {
+    options.compilerArgs.add("-Xlint:-deprecation")
+}
+
+tasks.named<Jar>("jar") {
+    dependsOn(extractHiddenapibypass)
+    from(zipTree(hiddenapibypassClassesJar))
+}
