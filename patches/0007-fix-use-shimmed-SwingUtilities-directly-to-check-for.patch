From 8ed30215adbf2650d3abe20a5a3b07c3a4e96fc5 Mon Sep 17 00:00:00 2001
From: Akash Yadav <akashyadav@appdevforall.org>
Date: Thu, 26 Mar 2026 14:37:27 +0530
Subject: [PATCH 7/9] fix: use shimmed SwingUtilities directly to check for
 event dispatcher thread

Since we already have a shimmed SwingUtilities class compatible with
Android runtime, we can use it directly instead of the going the MockApplication
way, which may change and break things.

Signed-off-by: Akash Yadav <akashyadav@appdevforall.org>
---
 .../impl/base/permissions/KaBaseAnalysisPermissionChecker.kt  | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/analysis/analysis-api-impl-base/src/org/jetbrains/kotlin/analysis/api/impl/base/permissions/KaBaseAnalysisPermissionChecker.kt b/analysis/analysis-api-impl-base/src/org/jetbrains/kotlin/analysis/api/impl/base/permissions/KaBaseAnalysisPermissionChecker.kt
index 17fe373e1130..682c3551264e 100644
--- a/analysis/analysis-api-impl-base/src/org/jetbrains/kotlin/analysis/api/impl/base/permissions/KaBaseAnalysisPermissionChecker.kt
+++ b/analysis/analysis-api-impl-base/src/org/jetbrains/kotlin/analysis/api/impl/base/permissions/KaBaseAnalysisPermissionChecker.kt
@@ -11,6 +11,7 @@ import org.jetbrains.kotlin.analysis.api.permissions.KaAnalysisPermissionRegistr
 import org.jetbrains.kotlin.analysis.api.platform.KaCachedService
 import org.jetbrains.kotlin.analysis.api.platform.permissions.KaAnalysisPermissionChecker
 import org.jetbrains.kotlin.analysis.api.platform.permissions.KotlinAnalysisPermissionOptions
+import javax.swing.SwingUtilities
 
 internal class KaBaseAnalysisPermissionChecker : KaAnalysisPermissionChecker {
     // We cache several services to avoid repeated `getService` calls in `analyze` and validity assertions.
@@ -53,8 +54,7 @@ internal class KaBaseAnalysisPermissionChecker : KaAnalysisPermissionChecker {
     }
 
     private fun isProhibitedEdtAnalysis(application: Application): Boolean =
-        application.isDispatchThread &&
-                !permissionOptions.defaultIsAnalysisAllowedOnEdt &&
+        SwingUtilities.isEventDispatchThread() && !permissionOptions.defaultIsAnalysisAllowedOnEdt &&
                 !permissionRegistry.isAnalysisAllowedOnEdt
 
     private fun isProhibitedWriteActionAnalysis(application: Application): Boolean =
-- 
